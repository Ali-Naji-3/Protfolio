---
/**
 * Chapter shell — the film's scene grammar (10 §rules 3/4/9).
 *
 * Every chapter opens with a full-screen SCENE CARD: chapter number as a
 * ghosted numeral (camera parallax layer), the title in the subtitle voice,
 * and a registered footage mount (`SCN-xx/open`). While the mount's src is
 * empty the card is a code-authored title scene; real footage drops in via
 * the asset manager with zero component changes.
 *
 * `hideCard` (hero) keeps a visually-hidden heading so the document outline
 * and aria-labelledby survive the cinematic treatment (08 §3).
 */
import type { ChapterId } from '@config/site';
import { CHAPTERS } from '@config/site';
import { getAsset, hasAsset } from '@config/assets';

interface Props {
  id: ChapterId;
  /** Chapter carries its own opening (e.g. the hero) — no scene card. */
  hideCard?: boolean;
}

const { id, hideCard = false } = Astro.props;
const chapter = CHAPTERS.find((c) => c.id === id)!;

const sceneId = `SCN-${chapter.num}/open`;
const scene = hasAsset(sceneId) ? getAsset(sceneId) : null;
const hasFootage = scene !== null && scene.src.length > 0;
---

<section class="chapter" id={id} data-chapter={id} aria-labelledby={`${id}-heading`}>
  {
    hideCard ? (
      <h2 class="visually-hidden" id={`${id}-heading`}>
        {chapter.title}
      </h2>
    ) : (
      <header class="scene" data-scene-open>
        {hasFootage && (
          <video
            class="scene__footage"
            data-scene-footage
            src={scene.src}
            poster={scene.poster}
            muted
            loop
            autoplay
            playsinline
            aria-label={scene.alt}
          />
        )}
        {/* Decorative numeral rendered via CSS content — invisible to both
            screen readers and contrast auditing, as decoration should be. */}
        <span class="scene__ghost mono" data-scene-ghost data-num={chapter.num} aria-hidden="true"
        ></span>
        <div class="scene__title-block" data-scene-title>
          <p class="micro-caps" aria-hidden="true">Chapter {chapter.num}</p>
          <h2 class="scene__title" id={`${id}-heading`}>{chapter.title}</h2>
        </div>
      </header>
    )
  }
  <div class="chapter__body">
    <slot />
  </div>
</section>

<style>
  .chapter {
    padding: 0;
  }

  .chapter__body {
    padding: var(--space-12) var(--margin-page) var(--space-20);
  }

  /* ── The scene card: a frame of film, not a section header ────── */
  .scene {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--ink-0);
  }

  .scene__footage {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55; /* footage stays behind the title, always legible */
  }

  .scene__ghost {
    position: absolute;
    font-size: clamp(14rem, 40vw, 34rem);
    line-height: 1;
    color: var(--text-0);
    opacity: 0.04;
    user-select: none;
  }

  .scene__ghost::before {
    content: attr(data-num);
  }

  .scene__title-block {
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0 var(--margin-page);
  }

  .scene__title {
    font-size: var(--type-display-2);
    line-height: var(--leading-display-2);
  }
</style>
