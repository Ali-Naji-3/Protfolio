---
/**
 * Chapter 00 — Enter (02 §Ch00): wordmark + the sound invitation.
 * M1: static, server-rendered version. The cold-open choreography and the
 * audio island arrive in M5; the invitation button is inert-but-visible so
 * layout and copy are final now. Audio is OFF by default, always (06 §2).
 */
import { COPY } from '@content/copy';
import { SITE } from '@config/site';
---

<!-- Cold open (10 §rule-1): revealed and timed by the cinema module;
     plays once per session, any input skips it. Without JS (or with
     reduced motion) it never exists — the story starts at the wordmark. -->
<div class="cold-open" data-cold-open hidden aria-hidden="true">
  {COPY.enter.coldOpen.map((line) => <p class="subtitle" data-open-line>{line}</p>)}
</div>

<section class="enter" id="enter" data-chapter="enter" aria-label="Enter">
  <h1 class="enter__wordmark">
    <span class="enter__name">{SITE.name}</span>
    <span class="visually-hidden">— {SITE.role} · {SITE.focus}</span>
    <span class="enter__underscore" data-breathe aria-hidden="true"></span>
  </h1>
  <div class="enter__sound" data-sound-invitation hidden>
    <p class="micro-caps">{COPY.enter.soundInvitation}</p>
    <button class="enter__enable micro-caps" data-sound-enable>
      [ {COPY.enter.soundEnable} ]
    </button>
  </div>
</section>

<style>
  .enter {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
  }

  .enter__wordmark {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .enter__name {
    font-family: var(--font-display);
    font-size: var(--type-display-2);
    line-height: var(--leading-display-2);
    font-weight: 500;
    color: var(--text-0);
    letter-spacing: var(--tracking-display);
  }

  .enter__underscore {
    width: 100%;
    height: 1px;
    background: var(--cyan-1);
    opacity: 0.2;
  }

  .enter__sound[hidden] {
    display: none;
  }

  .enter__sound {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .enter__enable {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-1);
    transition: color var(--t-1) var(--ease-drift);
  }

  .enter__enable:hover {
    color: var(--cyan-1);
  }
</style>
