---
/**
 * Chapter 03 — The Author (02 §Ch03). The human reveal: real Ali,
 * identity-validated (07). M1 uses the HUM-01 placeholder via the asset
 * manager; swapping in the validated portrait (M7) touches assets.ts only.
 */
import ChapterShell from '@components/ChapterShell.astro';
import { COPY } from '@content/copy';
import { getAsset } from '@config/assets';

const portrait = getAsset('HUM-01/author');
---

<ChapterShell id="author">
  <div class="author">
    <figure class="author__portrait" data-reveal>
      <img
        src={portrait.src}
        alt={portrait.alt}
        width={portrait.width}
        height={portrait.height}
        loading="lazy"
      />
    </figure>
    <div class="author__copy">
      <p class="author__intro" data-reveal>{COPY.author.intro}</p>
      <ul class="author__facts" role="list" data-reveal-group>
        {COPY.author.facts.map((fact) => <li>{fact}</li>)}
      </ul>
    </div>
  </div>
</ChapterShell>

<style>
  .author {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 3fr);
    gap: var(--space-8);
    align-items: center;
    min-height: 80svh;
  }

  .author__intro {
    font-family: var(--font-display);
    font-size: var(--type-display-3);
    line-height: var(--leading-display-3);
    color: var(--text-0);
    font-weight: 500;
  }

  .author__facts {
    list-style: none;
    padding: 0;
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--text-2);
  }

  @media (max-width: 767px) {
    .author {
      grid-template-columns: 1fr;
    }
  }
</style>
