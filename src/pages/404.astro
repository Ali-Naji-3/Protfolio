---
/**
 * 404 — stays inside the world: a lookup that affected zero rows.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@config/site';
---

<BaseLayout title={`Not found — ${SITE.name}`}>
  <main class="lost" id="content">
    <p class="mono lost__code">404</p>
    <h1 class="lost__title">SELECT page → 0 rows</h1>
    <p class="lost__body">This address doesn't exist in the system. The story does.</p>
    <a class="link" href="/">Return to the beginning</a>
  </main>
</BaseLayout>

<style>
  .lost {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    text-align: center;
    padding: var(--margin-page);
  }

  .lost__code {
    color: var(--warn-1);
    letter-spacing: 0.2em;
  }

  .lost__title {
    font-size: var(--type-display-3);
    line-height: var(--leading-display-3);
  }

  .lost__body {
    color: var(--text-2);
  }
</style>
